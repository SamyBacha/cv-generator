{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cv-data.schema.json",
  "title": "CV Data",
  "description": "Structure des données du CV Proxym France",
  "type": "object",
  "required": ["personal", "about", "skills", "timeline", "education", "teaching", "languages", "hobbies", "missions"],
  "additionalProperties": false,
  "properties": {
    "personal": {
      "type": "object",
      "required": ["name", "role"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "about": {
      "type": "object",
      "required": ["intro", "expertise", "conclusion"],
      "additionalProperties": false,
      "properties": {
        "intro": { "type": "string" },
        "expertise": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "conclusion": { "type": "string" }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "items"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "items": { "type": "string" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineEntry"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/educationEntry"
      }
    },
    "teaching": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/educationEntry"
      }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "hobbies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mission"
      }
    },
    "visibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "about":     { "type": "boolean" },
        "skills":    { "type": "boolean" },
        "timeline":  { "type": "boolean" },
        "education": { "type": "boolean" },
        "teaching":  { "type": "boolean" },
        "languages": { "type": "boolean" },
        "hobbies":   { "type": "boolean" },
        "missions":  { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "timelineEntry": {
      "type": "object",
      "required": ["year", "label"],
      "additionalProperties": false,
      "properties": {
        "year":    { "type": "string", "minLength": 1 },
        "label":   { "type": "string", "minLength": 1 },
        "alt":     { "type": "boolean" },
        "current": { "type": "boolean" }
      }
    },
    "educationEntry": {
      "type": "object",
      "required": ["years", "degree", "org"],
      "additionalProperties": false,
      "properties": {
        "years":  { "type": "string", "minLength": 1 },
        "degree": { "type": "string", "minLength": 1 },
        "org":    { "type": "string", "minLength": 1 }
      }
    },
    "task": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "desc":  { "type": "string" }
      }
    },
    "mission": {
      "type": "object",
      "required": ["dates", "client", "role", "summary", "tasks", "stack"],
      "additionalProperties": false,
      "properties": {
        "dates":   { "type": "string", "minLength": 1 },
        "client":  { "type": "string", "minLength": 1 },
        "role":    { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "logo":    { "type": "string" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        },
        "stack": { "type": "string" }
      }
    }
  }
}
